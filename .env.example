# MongoDB
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=bakars_food_catering

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=bakars-food-images
R2_PUBLIC_URL=https://your-r2-public-url.com

# Stripe
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-live-webhook-secret
STRIPE_TEST_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_TEST_WEBHOOK_SECRET=whsec_your-test-webhook-secret
STRIPE_TEST_MODE=true
STRIPE_CURRENCY=AUD

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Business Location
BUSINESS_LATITUDE=-33.8523
BUSINESS_LONGITUDE=150.9843
BUSINESS_ADDRESS=Woodville Rd Guildford 2161
BUSINESS_TIMEZONE=Australia/Sydney

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=info@bakarsfood.com.au
SMTP_FROM_NAME=Bakar's Food & Catering
SMTP_USE_TLS=true
CONTACT_RECIPIENT_EMAIL=info@bakarsfood.com.au
ORDER_NOTIFICATIONS_EMAIL=bakarfoods@gmail.com

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Environment
ENVIRONMENT=development
FRONTEND_BASE_URL=http://localhost:5173
